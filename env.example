# =============================================================================
# Mangle — Backend (Next.js + Hardhat) — variables de entorno
# Renombrá a `.env.local` (desarrollo) o `.env.production` (prod).
# El sufijo _MAINNET aplica cuando NEXT_PUBLIC_CELO_NETWORK=mainnet.
# Marcá como SECRETO: CELO_PRIVATE_KEY*, SUPABASE_SERVICE_KEY.
# =============================================================================

NODE_ENV=development

# Red activa: sepolia | mainnet
NEXT_PUBLIC_CELO_NETWORK=sepolia

# URLs de la app (Auth redirects / canónica)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Celo Sepolia (testnet) — variables SIN sufijo
# -----------------------------------------------------------------------------
CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
# Clave privada del wallet de desembolsos (FLD / hot wallet) — SECRETO
CELO_PRIVATE_KEY=

# MockCopm en testnet (sos owner → mint libre). El deploy del LendingPool lee ESTA
# variable (deploy-lending-pool.mjs) → el pool quedará casado a este token (immutable).
# DEBE coincidir EXACTO con VITE_COPM_SEPOLIA del frontend.
NEXT_PUBLIC_COPM_CONTRACT=0x6C732d66805da10bdd76F00bd05EA9eF9E66577f
# ⚠️ Reemplazar por la address del pool-mock nuevo tras redeployar.
NEXT_PUBLIC_LENDING_POOL_CONTRACT=0xTU_LENDING_POOL_MOCK_SEPOLIA
NEXT_PUBLIC_CELOSCAN_BASE_URL=https://celo-sepolia.blockscout.com

# -----------------------------------------------------------------------------
# Celo Mainnet (producción) — variables con sufijo _MAINNET
# -----------------------------------------------------------------------------
CELO_RPC_URL_MAINNET=https://forno.celo.org
CELO_PRIVATE_KEY_MAINNET=
NEXT_PUBLIC_COPM_CONTRACT_MAINNET=0x8A567e2aE79CA692Bd748aB832081C45de4041eA
NEXT_PUBLIC_LENDING_POOL_CONTRACT_MAINNET=0xTU_LENDING_POOL_MAINNET
NEXT_PUBLIC_CELOSCAN_BASE_URL_MAINNET=https://celoscan.io

# -----------------------------------------------------------------------------
# Plataforma
# -----------------------------------------------------------------------------
# Wallet que recibe los pagos (FLD) — en modo transfer directo
NEXT_PUBLIC_PLATFORM_WALLET_ADDRESS=0xTU_PLATFORM_WALLET

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clave de servicio (admin) — SECRETO, respeta esto
SUPABASE_SERVICE_KEY=

# -----------------------------------------------------------------------------
# Scripts (opcional)
# -----------------------------------------------------------------------------
# FUND_AMOUNT=1000
# MOCK_COPM ya NO se usa — el proyecto migró al COPm oficial de Mento.
